{
	"compilerOptions": {
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"target": "ES2022",
		"jsx": "react-jsx",
		"allowImportingTsExtensions": true,
		"strictNullChecks": true,
		"strictFunctionTypes": true,
		"baseUrl": ".",
		"paths": {
			"@components/*": ["components/*"],
			"@scooting/*": ["components/scooting/*"],
			"@models/*": ["models/*"],
			"@controllers": ["controllers/*"]
		}
	}
}
